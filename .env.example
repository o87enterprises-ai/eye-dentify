# Application
APP_NAME=Video Reverse Search
APP_VERSION=1.0.0
DEBUG=False
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/videosearch
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@db:5432/videosearch

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Storage
STORAGE_BASE=/data
FRAMES_DIR=/data/frames
FEATURES_DIR=/data/features
INDEX_DIR=/data/index
VIDEOS_DIR=/data/videos

# YouTube
YT_MAX_DURATION=3600
YT_FORMAT=bestvideo[ext=mp4]+bestaudio[ext=m44]/best[ext=mp4]/best

# ML
MODEL_NAME=resnet50
FRAME_INTERVAL=60
SIMILARITY_THRESHOLD=0.5
TOP_K_RESULTS=10
FAISS_INDEX_DIM=2048

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30
