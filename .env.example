# ========================================
# Eye-Dentify Environment Variables
# ========================================

# Application
APP_NAME=Eye-Dentify
APP_VERSION=1.0.0
DEBUG=False
API_PREFIX=/api/v1

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/videosearch
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@db:5432/videosearch

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Storage
STORAGE_BASE=/data
FRAMES_DIR=/data/frames
FEATURES_DIR=/data/features
INDEX_DIR=/data/index
VIDEOS_DIR=/data/videos

# YouTube
YT_MAX_DURATION=3600
YT_FORMAT=bestvideo[ext=mp4]+bestaudio[ext=m44]/best[ext=mp4]/best

# ML
MODEL_NAME=resnet50
FRAME_INTERVAL=60
SIMILARITY_THRESHOLD=0.5
TOP_K_RESULTS=10
FAISS_INDEX_DIM=2048

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30

# ========================================
# Authentication
# ========================================
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ========================================
# Email Verification
# ========================================
# Options: mock | resend | smtp
EMAIL_PROVIDER=mock

# Resend (free: 3000 emails/month)
RESEND_API_KEY=

# SMTP (works with Gmail, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@eyedentify.app
SMTP_USE_TLS=true

# ========================================
# Free Tier
# ========================================
FREE_TIER_DAILY_LIMIT=1

# ========================================
# Ad Configuration (Frontend)
# ========================================
# Options: mock | google
VITE_AD_PROVIDER=mock
VITE_GOOGLE_AD_CLIENT=
VITE_GOOGLE_AD_REWARDED_SLOT=
VITE_GOOGLE_AD_BANNER_SLOT=
